{
  // breadcumbs
  "breadcrumbs.enabled": false,

  // chat
  "chat.commandCenter.enabled": false,
  "chat.experimental.offerSetup": false,

  // editor
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.bracketPairColorization.enabled": false,
  "editor.comments.insertSpace": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.fontFamily": "'CommitMono Nerd Font'",
  "editor.fontSize": 14,
  "editor.hover.enabled": true,
  "editor.lineHeight": 28,
  "editor.minimap.enabled": false,
  "editor.parameterHints.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.rulers": [ 100 ],
  "editor.smoothScrolling": true,
  "editor.unicodeHighlight.allowedCharacters": {
    "á": true,
    "Á": true,
    "à": true,
    "À": true,
    "â": true,
    "Â": true,
    "ã": true,
    "Ã": true,
    "ç": true,
    "Ç": true,
    "é": true,
    "É": true,
    "è": true,
    "È": true,
    "ê": true,
    "Ê": true,
    "í": true,
    "Í": true,
    "ì": true,
    "Ì": true,
    "î": true,
    "Î": true,
    "ó": true,
    "Ó": true,
    "ò": true,
    "Ò": true,
    "ô": true,
    "Ô": true,
    "õ": true,
    "Õ": true,
    "ú": true,
    "Ú": true,
    "ù": true,
    "Ù": true,
    "û": true,
    "Û": true
  },
  "editor.unicodeHighlight.nonBasicASCII": true,

  // explorer
  "explorer.compactFolders": true,
  "explorer.excludeGitIgnore": true,
  "explorer.sortOrder": "type",
  "explorer.sortOrderLexicographicOptions": "upper",

  // extensions
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "extensions.closeExtensionDetailsOnViewChange": true,
  "extensions.ignoreRecommendations": true,

  // files
  "files.associations": { "*.json": "jsonc" },
  "files.autoSave": "off",
  "files.autoSaveWorkspaceFilesOnly": true,
  "files.enableTrash": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  // json
  "json.format.keepLines": true,

  // notebook
  "notebook.defaultFormatter": "ms-python.black-formatter",
  "notebook.dragAndDropEnabled": false,
  "notebook.output.textLineLimit": 60,

  // security
  "security.allowedUNCHosts": [ "wsl.localhost" ],
  "security.workspace.trust.enabled": false,

  // terminal
  "terminal.integrated.confirmOnKill": "never",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "Fish",
  "terminal.integrated.defaultProfile.windows": "PowerShell 7",

  "terminal.integrated.profiles.linux": {
    "Fish": {
      "path": "/usr/bin/fish",
      "args": [ ],
      "icon": "terminal",
      "overrideName": true
    }
  },

  "terminal.integrated.profiles.windows": {
    "PowerShell 7": {
      "path": "pwsh.exe",
      "args": [ "-Interactive", "-NoLogo" ],
      "icon": "terminal",
      "overrideName": true
    }
  },

  // window
  "window.menuBarVisibility": "compact",
  "window.newWindowDimensions": "maximized",
  "window.restoreWindows": "none",

  // workbench
  "workbench.activityBar.location": "hidden",
  "workbench.editor.navigationScope": "editor",
  "workbench.editor.showTabs": "none",
  "workbench.iconTheme": "vs-minimal",
  "workbench.panel.opensMaximized": "always",
  "workbench.settings.editor": "json",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": false,

  "[json]": { "editor.defaultFormatter": "vscode.json-language-features" },

  "[jsonc]": { "editor.defaultFormatter": "vscode.json-language-features" },

  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" },

  // charliermarsh.ruff
  "ruff.importStrategy": "useBundled",
  "ruff.lineLength": 99,
  "ruff.nativeServer": "on",
  "ruff.showNotifications": "onWarning",

  // ms-python.python
  "python.analysis.autoFormatStrings": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.gotoDefinitionInStringLiteral": true,
  "python.analysis.typeCheckingMode": "standard",
  "python.terminal.activateEnvironment": false,

  // ms-python.black-formatter
  "black-formatter.args": [ "--line-length", "99" ],
  "black-formatter.importStrategy": "useBundled",
  "black-formatter.showNotifications": "onWarning",

  // ms-python.isort
  "isort.args": [ "--profile", "black", "--line-length", "99" ],
  "isort.importStrategy": "useBundled",
  "isort.showNotifications": "onWarning",

  // ms-toolsai.jupyter
  "jupyter.askForKernelRestart": false,
  "jupyter.disableJupyterAutoStart": true,
  "jupyter.notebookFileRoot": "${workspaceFolder}",

  // ms-vscode.powershell
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.integratedConsole.suppressStartupBanner": true,
  "powershell.powerShellAdditionalExePaths": { "PowerShell 7": "C:\\Program Files\\PowerShell\\7\\pwsh.exe" },
  "powershell.powerShellDefaultVersion": "PowerShell 7"
}
